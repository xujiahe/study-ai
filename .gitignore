# ── 依赖 ──────────────────────────────────────────────────────────────────────
**/node_modules/
.pnpm-store/
.yarn/

# ── 构建产物 ──────────────────────────────────────────────────────────────────
**/dist/
**/build/
*.tsbuildinfo

# ── 环境变量（含 API Key，绝对不能提交）─────────────────────────────────────
.env
.env.local
.env.*.local

# ── 锁文件（可选，保留 package-lock.json / pnpm-lock.yaml 其中一种即可）────
# pnpm-lock.yaml
# package-lock.json
# bun.lock

# ── 日志 ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*

# ── 运行时临时文件 ────────────────────────────────────────────────────────────
**/workspace/
*.tmp
*.temp

# ── IDE / 编辑器 ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── 系统文件 ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── cloud-code（提取的第三方包，体积大，不需要提交）─────────────────────────
cloud-code/

# ── 测试覆盖率 ────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
