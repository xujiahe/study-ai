# ── LLM Provider ──────────────────────────────────────────────────────────────
# anthropic | openai | ollama | zhipu
LLM_PROVIDER=zhipu
LLM_MODEL=glm-5.1

# ── API Keys ──────────────────────────────────────────────────────────────────
ZHIPU_API_KEY=your_zhipu_key_here
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_DOCS_PATH=./docs
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# ── Server ────────────────────────────────────────────────────────────────────
# 每个 agent 服务端各自配置端口，UI 通过 VITE_API_URL 指向对应服务
# autogen:   SERVER_PORT=3001
# langgraph: SERVER_PORT=3002

# ── RAG Service ───────────────────────────────────────────────────────────────
# Agent 侧：指向 rag-service 地址
RAG_SERVICE_URL=http://localhost:3003
RAG_API_KEY=your-rag-api-key-here

# rag-service 自身配置（在 agents/rag-service/.env 中设置）
# RAG_SERVICE_PORT=3003
# RAG_MILVUS_ADDRESS=localhost:19530
# RAG_MILVUS_COLLECTION=rag_chunks
# RAG_UPLOAD_DIR=./uploads
# RAG_DB_PATH=./data/rag.db
# RAG_INDEX_CONCURRENCY=2
# RAG_MAX_FILE_SIZE_MB=10
