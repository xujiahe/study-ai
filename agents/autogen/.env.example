# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
ZHIPU_API_KEY=d2076bb2642a439c968962a7f05df63b.07SFrJo3fVOHHkba

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Global default provider: anthropic | openai | ollama | zhipu
LLM_PROVIDER=zhipu

# Global default model (leave blank to use provider default)
# anthropic defaults : claude-opus-4-5
# openai defaults    : gpt-4o
# ollama defaults    : llama3.2
# zhipu defaults     : glm-4.5
#   其他可选: glm-4.5-air | glm-4.5-flash (免费) | glm-4.5v (多模态)
LLM_MODEL=glm-4.5

# 智谱深度思考模式 (glm-4.5 / glm-4.5-air / glm-4.5v 支持)
ZHIPU_THINKING=false

# ── Ollama (local models) ─────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── RAG settings ──────────────────────────────────────────────────────────────
RAG_DOCS_PATH=./docs
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# ── MCP server ────────────────────────────────────────────────────────────────
MCP_SERVER_PORT=3100
