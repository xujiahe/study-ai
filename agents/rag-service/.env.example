# ─── RAG Service 配置 ──────────────────────────────────────────────────────────

# HTTP 服务端口
RAG_SERVICE_PORT=3003

# API 鉴权 Key（必需）— 所有请求均需在 X-API-Key header 中携带此值
RAG_API_KEY=my-local-dev-key-123

# ─── Milvus 向量数据库 ─────────────────────────────────────────────────────────

# Milvus gRPC 地址（Docker 部署时通常为 localhost:19530 或 milvus:19530）
RAG_MILVUS_ADDRESS=localhost:19530

# Milvus Collection 名称
RAG_MILVUS_COLLECTION=rag_chunks

# ─── 存储路径 ──────────────────────────────────────────────────────────────────

# 上传文件存储目录（相对于服务工作目录）
RAG_UPLOAD_DIR=./uploads

# SQLite 元数据数据库路径
RAG_DB_PATH=./data/rag.db

# ─── 性能调优 ──────────────────────────────────────────────────────────────────

# 并发索引任务数（同时处理的文档数量上限）
RAG_INDEX_CONCURRENCY=2

# 上传文件大小限制（单位：MB）
RAG_MAX_FILE_SIZE_MB=10

# 文本分块大小（字符数）
RAG_CHUNK_SIZE=500

# 分块重叠大小（字符数，用于保持上下文连贯性）
RAG_CHUNK_OVERLAP=50

# ─── Embedding 模型 ────────────────────────────────────────────────────────────

# 智谱 API Key（优先使用，embedding-3 模型，向量维度 2048）
# 申请地址：https://open.bigmodel.cn/
ZHIPU_API_KEY=

# OpenAI API Key（备用，text-embedding-3-small 模型，向量维度 1536）
OPENAI_API_KEY=

# Embedding 向量维度（使用智谱时设为 2048，使用 OpenAI 时设为 1536）
# 注意：切换模型后需重建 Milvus Collection 和重新索引所有文档
EMBEDDING_DIM=1536
