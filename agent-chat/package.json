{
  "name": "agent-chat",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:autogen": "cross-env VITE_API_URL=http://localhost:3001 vite",
    "dev:langgraph": "cross-env VITE_API_URL=http://localhost:3002 vite",
    "dev:chat": "cross-env VITE_CHAT_URL=http://localhost:3010 vite --port 5174",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@study-ai/chat-shared": "workspace:*",
    "@vueuse/core": "^11.0.0",
    "dompurify": "^3.2.0",
    "highlight.js": "^11.10.0",
    "marked": "^14.0.0",
    "marked-highlight": "^2.2.4",
    "pinia": "^2.2.0",
    "uuid": "^10.0.0",
    "vue": "^3.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-vue": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.47",
    "typescript": "^5.6.0",
    "vite": "^6.3.0",
    "vue-tsc": "^2.1.0"
  }
}
